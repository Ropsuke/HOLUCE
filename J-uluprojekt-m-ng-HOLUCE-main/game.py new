# --- PROCEDURAL GENERATION ---
def generate_dungeon(width, height, floor_level):
    # 1. Teeme seinad
    grid = [['W' for _ in range(width)] for _ in range(height)]
    
    # 2. Seadistame walker-i
    cx, cy = width // 2, height // 2
    walker_x, walker_y = cx, cy
    
    # 3. Hoiame meeles põranda koordinaate (et vältida seinte sisse panemist)
    floor_tiles = []
    
    # Märgime stardi
    grid[cy][cx] = '.'
    floor_tiles.append((cx, cy))
    
    # 4. Kõndimine (The Walk)
    target_floors = int((width * height) * 0.4)
    steps_taken = 0
    
    while len(floor_tiles) < target_floors and steps_taken < 2000:
        steps_taken += 1
        direction = random.choice([(0, 1), (0, -1), (1, 0), (-1, 0)])
        next_x = walker_x + direction[0]
        next_y = walker_y + direction[1]
        
        # Piiride kontroll
        if 1 < next_x < width - 1 and 1 < next_y < height - 1:
            walker_x, walker_y = next_x, next_y
            
            if grid[walker_y][walker_x] == 'W':
                grid[walker_y][walker_x] = '.'
                floor_tiles.append((walker_x, walker_y))

    # 5. Paneme mängija (Esimene põrandaplaat)
    start_pos = floor_tiles[0]
    # Me ei joonista 'P'-d kaardile, sest Player klass joonistab ennast ise,
    # aga märgime ruudustikus, et see pole sein.
    grid[start_pos[1]][start_pos[0]] = 'P' 
    
    # 6. Paneme trepi (Viimane põrandaplaat)
    stair_pos = floor_tiles[-1]
    
    # Väike kontroll, et trepp ei oleks stardi peal (kui kaart on liiga väike)
    if stair_pos == start_pos and len(floor_tiles) > 1:
        stair_pos = floor_tiles[-2]
        
    grid[stair_pos[1]][stair_pos[0]] = 'S'
    
    # 7. Teeme asjad ja vaenlased
    map_data = ["".join(row) for row in grid]
    items = []
    enemies = []
    
    # Võtame kõik põrandad, VÄLJA ARVATUD start ja trepp
    valid_spots = [t for t in floor_tiles if t != start_pos and t != stair_pos]
    
    for tile in valid_spots:
        tx, ty = tile
        roll = random.random()
        
        # 3% Vaenlane
        if roll < 0.03:
            hp = 20 + (floor_level * 5)
            dmg = 2 + floor_level
            name = random.choice(["Rat", "Bat", "Slime", "Goblin"])
            enemies.append(Enemy(tx, ty, name, hp, dmg))
            
        # 2% Sanity jook
        elif roll < 0.05:
            items.append(Item(tx, ty, "sanity"))
            
        # 1% Ultimatum jook
        elif roll < 0.06:
            items.append(Item(tx, ty, "ultimatum"))

    # 8. Lõpetame ja saadame andmed tagasi (AINULT ÜKS RETURN LÕPUS)
    return map_data, start_pos, items, enemies







# --- CLASSES ---

class GameMap:
    def __init__(self, data, is_safe_zone=False):
        self.data = data
        self.height = len(data)
        self.width = len(data[0])
        self.is_safe_zone = is_safe_zone

    def draw(self, surface):
        for row_index, row in enumerate(self.data):
            for col_index, tile in enumerate(row):
                x = col_index * TILE_SIZE
                y = row_index * TILE_SIZE
                
                if tile == 'W':
                    pygame.draw.rect(surface, COLOR_WALL, (x, y, TILE_SIZE, TILE_SIZE))
                elif tile == 'D':
                    pygame.draw.rect(surface, COLOR_DOOR, (x, y, TILE_SIZE, TILE_SIZE))
                    pygame.draw.rect(surface, (0,0,0), (x + 20, y + 10, 24, 44)) 
                elif tile == 'S': # Stairs
                    pygame.draw.rect(surface, COLOR_FLOOR, (x, y, TILE_SIZE, TILE_SIZE))
                    pygame.draw.rect(surface, COLOR_STAIRS, (x + 10, y + 10, 44, 44))
                    pygame.draw.rect(surface, (0,0,0), (x + 20, y + 20, 24, 24))
                else:
                    color = COLOR_GRASS if self.is_safe_zone else COLOR_FLOOR
                    pygame.draw.rect(surface, color, (x, y, TILE_SIZE, TILE_SIZE))
                    pygame.draw.rect(surface, (40,40,40), (x, y, TILE_SIZE, TILE_SIZE), 1)

    def is_solid(self, x, y):
        if 0 <= x < self.width and 0 <= y < self.height:
            return self.data[y][x] == 'W'
        return True

    def get_tile(self, x, y):
        if 0 <= x < self.width and 0 <= y < self.height:
            return self.data[y][x]
        return None

class Enemy:
    def __init__(self, x, y, name, hp, damage):
        self.grid_x = x
        self.grid_y = y
        self.name = name
        self.max_hp = hp
        self.hp = hp
        self.damage = damage
        
    def draw(self, surface):
        pixel_x = self.grid_x * TILE_SIZE
        pixel_y = self.grid_y * TILE_SIZE
        pygame.draw.rect(surface, COLOR_ENEMY, (pixel_x + 10, pixel_y + 10, TILE_SIZE - 20, TILE_SIZE - 20))
        ratio = self.hp / self.max_hp
        pygame.draw.rect(surface, (255,0,0), (pixel_x + 5, pixel_y - 5, 54, 5))
        pygame.draw.rect(surface, (0,255,0), (pixel_x + 5, pixel_y - 5, 54 * ratio, 5))

class Player:
    def __init__(self):
        self.grid_x = 1
        self.grid_y = 1
        self.map = None
        
        # Stats
        self.max_hp = 100
        self.hp = self.max_hp
        self.max_sanity = 100
        self.sanity = self.max_sanity
        self.current_floor = 0
        self.damage = 10 
        
        self.base_drain_rate = 0.05
        self.drain_increase_per_floor = 0.02
        
        self.move_timer = 0
        self.move_delay = 150 

    def set_map(self, new_map, start_pos=None):
        self.map = new_map
        if start_pos:
            self.grid_x, self.grid_y = start_pos
        else:
            for r, row in enumerate(self.map.data):
                for c, tile in enumerate(row):
                    if tile == 'P':
                        self.grid_x, self.grid_y = c, r

    def move(self, dx, dy, enemies_list):
        if not self.map: return

        new_x = self.grid_x + dx
        new_y = self.grid_y + dy

        if not self.map.is_solid(new_x, new_y):
            for enemy in enemies_list:
                if enemy.grid_x == new_x and enemy.grid_y == new_y:
                    return "COMBAT", enemy

            self.grid_x = new_x
            self.grid_y = new_y
            
            tile = self.map.get_tile(new_x, new_y)
            if tile == 'D': return "ENTER_DUNGEON", None
            if tile == 'S': return "NEXT_FLOOR", None

            if not self.map.is_safe_zone:
                current_drain = self.base_drain_rate + (self.current_floor * self.drain_increase_per_floor)
                self.sanity -= current_drain
                if self.sanity < 0: self.sanity = 0
        
        return None, None

    def update(self, enemies_list):
        keys = pygame.key.get_pressed()
        current_time = pygame.time.get_ticks()

        if current_time - self.move_timer > self.move_delay:
            dx, dy = 0, 0
            if keys[pygame.K_LEFT]: dx = -1
            elif keys[pygame.K_RIGHT]: dx = 1
            elif keys[pygame.K_UP]: dy = -1
            elif keys[pygame.K_DOWN]: dy = 1

            if dx != 0 or dy != 0:
                result, target = self.move(dx, dy, enemies_list)
                self.move_timer = current_time
                return result, target
        return None, None

    def draw(self, surface):
        pixel_x = self.grid_x * TILE_SIZE
        pixel_y = self.grid_y * TILE_SIZE
        pygame.draw.rect(surface, COLOR_PLAYER, (pixel_x, pixel_y, TILE_SIZE, TILE_SIZE))
        pygame.draw.circle(surface, (0,0,0), (pixel_x + 20, pixel_y + 20), 5)
        pygame.draw.circle(surface, (0,0,0), (pixel_x + 44, pixel_y + 20), 5)

class Item:
    def __init__(self, x, y, item_type):
        self.grid_x = x
        self.grid_y = y
        self.type = item_type 
    def draw(self, surface):
        pixel_x = self.grid_x * TILE_SIZE + (TILE_SIZE // 4)
        pixel_y = self.grid_y * TILE_SIZE + (TILE_SIZE // 4)
        size = TILE_SIZE // 2
        color = COLOR_VIAL if self.type == "sanity" else COLOR_ULTIMATUM
        pygame.draw.rect(surface, color, (pixel_x, pixel_y, size, size))
        pygame.draw.rect(surface, (200, 200, 200), (pixel_x + size//4, pixel_y - 5, size//2, 5))

class LetterSprite(pygame.sprite.Sprite):
    def __init__(self, image, target_x, target_y, start_delay):
        super().__init__()
        self.original_image = image
        self.image = image.copy()
        self.start_y = -START_OFFSET
        self.rect = self.image.get_rect(midbottom=(target_x, self.start_y))
        self.alpha = 0
        self.image.set_alpha(self.alpha)
        self.target_y = target_y
        self.current_y = float(self.rect.y)
        self.delay = start_delay
        self.falling = True 
        self.float_amplitude = 10
        self.float_speed = 0.05
        self.float_phase = start_delay * 0.1
        self.base_y = target_y

    def update(self):
        if self.delay > 0:
            self.delay -= 1
            return
        if self.alpha < 255:
            self.alpha += FADE_SPEED
            if self.alpha > 255: self.alpha = 255
            self.image = self.original_image.copy()
            self.image.set_alpha(self.alpha)
        if self.falling:
            self.current_y += DROP_SPEED
            if self.current_y >= self.base_y:
                self.current_y = self.base_y
                self.falling = False
            self.rect.y = int(self.current_y)
        else:
            self.float_phase += self.float_speed
            offset = math.sin(self.float_phase) * self.float_amplitude
            self.rect.y = int(self.base_y + offset)

# --- ASSET LOADING ---
letters = []
try:
    for char in WORD:
        filename = f"{char}.png"
        path = os.path.join(ASSET_FOLDER, filename)
        img = pygame.image.load(path).convert_alpha()
        img = pygame.transform.scale(img, (img.get_width() // 10, img.get_height() // 10))
        letters.append(img)
except:
    for char in WORD:
        s = pygame.Surface((50, 50))
        s.fill((200, 200, 200))
        letters.append(s)

sprites = pygame.sprite.Group()
total_letter_width = sum(img.get_width() for img in letters)
total_spacing = LETTER_SPACING * (len(letters) - 1)
total_width = total_letter_width + total_spacing
start_x = (WIDTH - total_width) // 2
x = start_x
for i, img in enumerate(letters):
    target_y = HEIGHT // 4
    char = WORD[i]
    offset = LETTER_OFFSETS.get(char, 0)
    sprite = LetterSprite(img, x + img.get_width() // 2 + offset, target_y, i * DELAY_BETWEEN)
    sprites.add(sprite)
    x += img.get_width() + LETTER_SPACING

# --- INITIALIZATION ---
player = Player()
items = [] 
enemies = []

spawn_map = GameMap(SPAWN_LEVEL, is_safe_zone=True)
player.set_map(spawn_map)

# --- STATES ---
STATE_TITLE = "title"
STATE_CUTSCENE = "cutscene"
STATE_GAME = "game"
STATE_BATTLE = "battle"
current_state = STATE_TITLE
cutscene_index = 0

# Combat variables
combat_enemy = None
combat_log = ""

# --- MAIN LOOP ---
running = True
while running:
    # 1. EVENT HANDLING
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False
        
        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_F11:
                pygame.display.toggle_fullscreen()
            
            if current_state == STATE_TITLE:
                if event.key == pygame.K_RETURN:
                    current_state = STATE_CUTSCENE
            
            elif current_state == STATE_CUTSCENE:
                if event.key == pygame.K_RETURN:
                    cutscene_index += 1
                    if cutscene_index >= len(STORY_LINES):
                        current_state = STATE_GAME
            
            elif current_state == STATE_GAME:
                if event.key == pygame.K_ESCAPE:
                    current_state = STATE_TITLE
                    cutscene_index = 0
            
            elif current_state == STATE_BATTLE:
                # BATTLE CONTROLS
                if event.key == pygame.K_SPACE: # ATTACK
                    damage = player.damage + random.randint(-2, 2)
                    combat_enemy.hp -= damage
                    combat_log = f"You hit {combat_enemy.name} for {damage} dmg!"
                    
                    if combat_enemy.hp > 0:
                        e_dmg = combat_enemy.damage + random.randint(-1, 1)
                        player.hp -= e_dmg
                        combat_log += f" | It hits you for {e_dmg}!"
                    else:
                        combat_log = f"You defeated {combat_enemy.name}!"

                if event.key == pygame.K_f: # FLEE
                    player.sanity -= 10
                    combat_log = "You ran away in fear! (-10 Sanity)"
                    combat_enemy = None
                    current_state = STATE_GAME

    # 2. LOGIC UPDATES & DRAWING
    SCREEN.fill((20, 20, 20))

    if current_state == STATE_TITLE:
        sprites.update()
        sprites.draw(SCREEN)
        if pygame.time.get_ticks() % 1000 < 500:
            font = pygame.font.SysFont("arial", 30)
            text = font.render("PRESS ENTER", True, (150, 150, 150))
            rect = text.get_rect(center=(WIDTH//2, HEIGHT - 100))
            SCREEN.blit(text, rect)

    elif current_state == STATE_CUTSCENE:
        SCREEN.fill((0, 0, 0))
        font = pygame.font.SysFont("georgia", 40)
        line = STORY_LINES[cutscene_index]
        text_surf = font.render(line, True, (255, 255, 255))
        text_rect = text_surf.get_rect(center=(WIDTH//2, HEIGHT//2))
        SCREEN.blit(text_surf, text_rect)
        small_font = pygame.font.SysFont("arial", 20)
        hint = small_font.render("[Press Enter]", True, (100, 100, 100))
        SCREEN.blit(hint, (WIDTH - 150, HEIGHT - 50))

    elif current_state == STATE_GAME or current_state == STATE_BATTLE:
        if current_state == STATE_GAME:
            action, target = player.update(enemies)
            
            if action == "ENTER_DUNGEON":
                print("Generating Floor 1...")
                player.current_floor = 1
                # FIX: Change size to 28, 15 (Fits in 1800x1000)
                raw_map, start_pos, items, enemies = generate_dungeon(28, 15, 1)
                player.set_map(GameMap(raw_map, is_safe_zone=False), start_pos)
            
            elif action == "NEXT_FLOOR":
                player.current_floor += 1
                print(f"Generating Floor {player.current_floor}...")
                # FIX: Change size to 28, 15
                raw_map, start_pos, items, enemies = generate_dungeon(28, 15, player.current_floor)
                player.set_map(GameMap(raw_map, is_safe_zone=False), start_pos)

            elif action == "COMBAT":
                current_state = STATE_BATTLE
                combat_enemy = target
                combat_log = f"A wild {combat_enemy.name} appears!"

        if player.map: player.map.draw(SCREEN)
        
        if not player.map.is_safe_zone:
            for item in items: item.draw(SCREEN)
            for item in items[:]: 
                if player.grid_x == item.grid_x and player.grid_y == item.grid_y:
                    if item.type == "sanity": player.sanity += 10
                    elif item.type == "ultimatum":
                        if random.random() < 0.5: player.sanity += 50
                        else: player.sanity -= 35
                    if player.sanity > player.max_sanity: player.sanity = player.max_sanity
                    items.remove(item)
            
            for enemy in enemies:
                if enemy.hp > 0: enemy.draw(SCREEN)
            
            if combat_enemy and combat_enemy.hp <= 0:
                if combat_enemy in enemies: enemies.remove(combat_enemy)
                if current_state == STATE_BATTLE and "defeated" in combat_log:
                     current_state = STATE_GAME
                     combat_enemy = None

        player.draw(SCREEN)

        font = pygame.font.SysFont(None, 24)
        
        pygame.draw.rect(SCREEN, (50, 0, 0), (20, 20, 200, 20))
        pygame.draw.rect(SCREEN, (200, 0, 0), (20, 20, (player.hp/player.max_hp)*200, 20))
        hp_txt = font.render(f"HP: {player.hp}", True, (255, 255, 255))
        SCREEN.blit(hp_txt, (25, 22))

        pygame.draw.rect(SCREEN, (20, 20, 50), (20, 50, 200, 20))
        pygame.draw.rect(SCREEN, (100, 0, 200), (20, 50, (player.sanity/player.max_sanity)*200, 20))
        san_txt = font.render(f"Sanity: {int(player.sanity)}", True, (255, 255, 255))
        SCREEN.blit(san_txt, (25, 52))
        
        floor_txt = font.render(f"Floor: {player.current_floor}", True, (200, 200, 100))
        SCREEN.blit(floor_txt, (240, 35))

        # ### LOOK HERE FOR CHALLENGE 3 ###
        if player.sanity < 50:
            darkness = pygame.Surface((WIDTH, HEIGHT)) # 1. Create Surface
            darkness.fill((0, 0, 0))                   # 2. Fill Color
            alpha = int((50 - player.sanity) * 4) 
            if alpha > 240: alpha = 240 
            darkness.set_alpha(alpha)                  # 3. Set Alpha
            SCREEN.blit(darkness, (0,0))               # 4. Blit

        if current_state == STATE_BATTLE and combat_enemy:
            overlay = pygame.Surface((WIDTH, HEIGHT))
            overlay.set_alpha(150)
            overlay.fill((0,0,0))
            SCREEN.blit(overlay, (0,0))
            
            box_rect = pygame.Rect(WIDTH//2 - 300, HEIGHT//2 - 200, 600, 400)
            pygame.draw.rect(SCREEN, COLOR_UI_BG, box_rect)
            pygame.draw.rect(SCREEN, COLOR_UI_BORDER, box_rect, 3)
            
            b_font = pygame.font.SysFont("arial", 30)
            title = b_font.render(f"BATTLE: {combat_enemy.name}", True, (255, 50, 50))
            SCREEN.blit(title, (box_rect.x + 20, box_rect.y + 20))
            
            e_hp_txt = b_font.render(f"Enemy HP: {combat_enemy.hp}/{combat_enemy.max_hp}", True, (255, 255, 255))
            SCREEN.blit(e_hp_txt, (box_rect.x + 20, box_rect.y + 70))
            
            p_hp_txt = b_font.render(f"Your HP: {player.hp}/{player.max_hp}", True, (100, 255, 100))
            SCREEN.blit(p_hp_txt, (box_rect.x + 20, box_rect.y + 110))
            
            log_txt = b_font.render(combat_log, True, (200, 200, 200))
            SCREEN.blit(log_txt, (box_rect.x + 20, box_rect.y + 200))
            
            controls = font.render("[SPACE] Attack    [F] Flee (-10 Sanity)", True, (255, 200, 0))
            SCREEN.blit(controls, (box_rect.x + 20, box_rect.y + 350))

    pygame.display.flip()
    CLOCK.tick(FPS)

pygame.quit()
sys.exit()
